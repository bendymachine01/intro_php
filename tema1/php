// ==========================
// 4. OPERADORES
// ==========================

echo "<h2>4. Operadores</h2>";

$a = 10;
$b = 5;

// Aritméticos
echo "Suma: " . ($a + $b) . "<br>";
echo "Resta: " . ($a - $b) . "<br>";
echo "Multiplicación: " . ($a * $b) . "<br>";
echo "División: " . ($a / $b) . "<br>";

// Comparación
echo "¿a es igual a b? ";
echo ($a == $b) ? "Sí<br>" : "No<br>";

echo "¿a es mayor que b? ";
echo ($a > $b) ? "Sí<br>" : "No<br>";

// Lógicos
echo "Operador AND (a > 5 && b < 10): ";
echo ($a > 5 && $b < 10) ? "Verdadero<br>" : "Falso<br>";


// ==========================
// 5. ARRAYS
// ==========================

echo "<h2>5. Arrays</h2>";

$colores = array("rojo", "azul", "verde");

echo "Primer color: " . $colores[0] . "<br>";
echo "Segundo color: " . $colores[1] . "<br>";


// ==========================
// 6. ARRAYS ASOCIATIVOS
// ==========================

echo "<h2>6. Arrays Asociativos</h2>";

$persona = array(
    "nombre" => "Juan",
    "edad" => 17,
    "ciudad" => "Bogotá"
);

echo "Nombre: " . $persona["nombre"] . "<br>";
echo "Edad: " . $persona["edad"] . "<br>";
echo "Ciudad: " . $persona["ciudad"] . "<br>";

